# ESSENCE Outbound Data project (xfamwraegljpmvsdimrp)
SUPABASE_URL=https://xfamwraegljpmvsdimrp.supabase.co
# Service role key — Supabase dashboard → Project Settings → API. Server-side only, never shipped to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for POST /api/audits (the generation trigger).
AUDITS_TRIGGER_SECRET=

# Copy generation (improved title, findings). Falls back to deterministic templates if unset.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Standout "after" image generation. Falls back to the original product photo if unset.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Live competitor research when ad_observations/serper cache have no cards. Optional.
SERPER_API_KEY=

# Dev only: AUDIT_MOCK=1 makes GET /api/audit serve the bundled grip6 payload without touching Supabase.
AUDIT_MOCK=
